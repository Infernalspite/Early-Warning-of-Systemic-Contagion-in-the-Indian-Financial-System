# Python & caches
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
env/
.env/
.venv/

# Jupyter / data science
.ipynb_checkpoints/
*.ipynb

